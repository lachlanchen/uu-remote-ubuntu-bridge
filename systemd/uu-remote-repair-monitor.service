[Unit]
Description=Resume UU Codex repair and monitor relay health
After=default.target

[Service]
Type=oneshot
ExecStart=%h/.local/bin/uu-remote-update monitor
TimeoutStartSec=2h
UMask=0077
Nice=10
IOSchedulingClass=idle
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=full
ProtectKernelTunables=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
LockPersonality=yes
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6 AF_NETLINK
