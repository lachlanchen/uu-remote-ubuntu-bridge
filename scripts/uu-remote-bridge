#!/usr/bin/env bash

set -Eeuo pipefail

bridge_user="${USER:-$(id -un)}"
bridge_display="${UURB_DISPLAY:-auto}"
rdp_port="${UURB_RDP_PORT:-3390}"
resolution="${UURB_RESOLUTION:-1920x1080}"
grd_fd_restart_threshold="${UURB_GRD_FD_RESTART_THRESHOLD:-4096}"
text_key_delay_ms="${UURB_TEXT_KEY_DELAY_MS:-8}"
physical_key_delay_ms="${UURB_PHYSICAL_KEY_DELAY_MS:-0}"
network_interface="${UURB_NETWORK_INTERFACE:-all}"
manager_display="${DISPLAY:-}"
manager_wayland="${WAYLAND_DISPLAY:-}"
manager_session_type="${XDG_SESSION_TYPE:-}"
manager_bus="${DBUS_SESSION_BUS_ADDRESS:-unix:path=${XDG_RUNTIME_DIR:-/run/user/$UID}/bus}"
systemctl_user=(
    /usr/bin/env
    "DBUS_SESSION_BUS_ADDRESS=unix:path=${XDG_RUNTIME_DIR:-/run/user/$UID}/bus"
    /usr/bin/systemctl --user
)

if [[ "$bridge_display" != auto &&
      ! "$bridge_display" =~ ^:(0|[1-9][0-9]{0,2})$ ]] ||
   [[ ! "$rdp_port" =~ ^[1-9][0-9]{0,4}$ ]] ||
   [[ ! "$resolution" =~ ^[1-9][0-9]{2,4}x[1-9][0-9]{2,4}$ ]] ||
   [[ ! "$grd_fd_restart_threshold" =~ ^[0-9]+$ ]] ||
   [[ ! "$text_key_delay_ms" =~ ^[0-9]+$ ]] ||
   [[ ! "$physical_key_delay_ms" =~ ^[0-9]+$ ]] ||
   [[ "$network_interface" != all &&
      "$network_interface" != default &&
      ! "$network_interface" =~ ^[a-zA-Z0-9_.:-]{1,15}$ ]]; then
    printf 'Invalid UURB display, RDP port, resolution, descriptor, keyboard, or network setting.\n' >&2
    exit 2
fi
resolution_width="${resolution%x*}"
resolution_height="${resolution#*x}"
if ((rdp_port < 1024 || rdp_port > 65535 ||
     resolution_width < 640 || resolution_width > 16384 ||
     resolution_height < 480 || resolution_height > 16384 ||
     (grd_fd_restart_threshold != 0 &&
      (grd_fd_restart_threshold < 512 ||
       grd_fd_restart_threshold > 60000)) ||
     text_key_delay_ms > 50 || physical_key_delay_ms > 50)); then
    printf 'UURB port, resolution, descriptor threshold, or keyboard delay is outside the supported range.\n' >&2
    exit 2
fi

if [[ "$bridge_display" == auto ]]; then
    for display_number in $(/usr/bin/seq 20 99); do
        if [[ ! -e "/tmp/.X11-unix/X$display_number" &&
              ! -e "/tmp/.X${display_number}-lock" ]]; then
            bridge_display=":$display_number"
            break
        fi
    done
    if [[ "$bridge_display" == auto ]]; then
        printf 'No free private X display was found from :20 through :99.\n' >&2
        exit 1
    fi
else
    display_number="${bridge_display#:}"
    if [[ -e "/tmp/.X11-unix/X$display_number" ||
          -e "/tmp/.X${display_number}-lock" ]]; then
        printf 'Private X display %s is already in use; choose auto or another display.\n' \
            "$bridge_display" >&2
        exit 1
    fi
fi

export DISPLAY="$bridge_display"
export WINEPREFIX="$HOME/.local/share/wineprefixes/uu-remote"
export WINEDEBUG=-all
export WINEDLLOVERRIDES='winedbg.exe=d;mscoree,mshtml='
export OPENSSL_MODULES='C:\Program Files\FreeRDP\ossl-modules'
export SDL_RENDER_DRIVER=software
export UU_INPUT_BRIDGE_LOG="C:\\users\\$bridge_user\\Temp\\uu-input-bridge.log"
export UU_INPUT_BROKER_LOG="C:\\users\\$bridge_user\\Temp\\uu-input-broker.log"
export UURB_TEXT_KEY_DELAY_MS="$text_key_delay_ms"
export UURB_PHYSICAL_KEY_DELAY_MS="$physical_key_delay_ms"
export PATH="/opt/wine-stable/bin:/usr/bin:/bin"

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/uu-remote-bridge"
runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$UID}/uu-remote-bridge"
compat_dir="$WINEPREFIX/compat"
libei_dir="$compat_dir/libei"
freerdp_exe="$WINEPREFIX/drive_c/Program Files/FreeRDP/sdl-freerdp.exe"
input_bridge_dll="$compat_dir/uu-input-bridge.dll"
input_broker_exe="$compat_dir/uu-input-broker.exe"
network_filter="$compat_dir/uu-network-filter.so"
input_injector_exe="$compat_dir/uu-injector.exe"
service_control_exe="$compat_dir/uu-service-control.exe"
uu_app_dir="$WINEPREFIX/drive_c/Program Files/Netease/GameViewer"
xauth_file="$runtime_dir/Xauthority"
wine_stop_bin="$HOME/.local/libexec/uu-remote-stop-wine-prefix"

if [[ ! -x "$libei_dir/libei.so.1.2.1" ||
      ! -L "$libei_dir/libei.so.1" ]]; then
    printf 'The patched libei keymap-FD backport is missing; reinstall the bridge.\n' >&2
    exit 1
fi

xvfb_pid=""
openbox_pid=""
grd_pid=""
freerdp_pid=""
winlogon_pid=""
input_broker_pid=""
server_supervisor_pid=""
grd_user_service_was_active=false
desktop_bus=""
desktop_display=""
desktop_wayland=""
desktop_session_type=""
active_network_interface=""

log() {
    printf '%s %s\n' "$(date --iso-8601=seconds)" "$*"
}

select_network_interface() {
    local candidate

    [[ "$network_interface" != all ]] || return 0
    if [[ "$network_interface" == default ]]; then
        candidate="$(default_network_interface)"
    else
        candidate="$network_interface"
    fi
    if [[ -n "$candidate" && -d "/sys/class/net/$candidate" ]]; then
        active_network_interface="$candidate"
        log "UU adapter selection is limited to $candidate plus loopback."
    else
        log "Configured UU adapter $network_interface is unavailable; preserving the unfiltered adapter list."
    fi
}

default_network_interface() {
    /usr/bin/ip -4 route show default 2>/dev/null | \
        /usr/bin/awk '
            {
                interface = ""
                route_metric = 0
                for (i = 1; i <= NF; ++i) {
                    if ($i == "dev")
                        interface = $(i + 1)
                    else if ($i == "metric")
                        route_metric = $(i + 1)
                }
                if (interface != "")
                    print route_metric, interface
            }
        ' | /usr/bin/sort -n -k1,1 | /usr/bin/awk 'NR == 1 {print $2}'
}

cleanup() {
    local display_lock
    local display_socket
    local lock_pid
    local pid
    local processes_alive

    trap - EXIT INT TERM HUP

    for pid in \
        "$server_supervisor_pid" \
        "$input_broker_pid" \
        "$winlogon_pid" \
        "$freerdp_pid" \
        "$grd_pid" \
        "$openbox_pid" \
        "$xvfb_pid"; do
        if [[ -n "$pid" ]]; then
            kill "$pid" >/dev/null 2>&1 || true
        fi
    done

    for _ in {1..10}; do
        processes_alive=false
        for pid in \
            "$server_supervisor_pid" \
            "$input_broker_pid" \
            "$winlogon_pid" \
            "$freerdp_pid" \
            "$grd_pid" \
            "$openbox_pid" \
            "$xvfb_pid"; do
            if [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1; then
                processes_alive=true
                break
            fi
        done
        [[ "$processes_alive" == false ]] && break
        sleep 0.1
    done

    for pid in \
        "$server_supervisor_pid" \
        "$input_broker_pid" \
        "$winlogon_pid" \
        "$freerdp_pid" \
        "$grd_pid" \
        "$openbox_pid" \
        "$xvfb_pid"; do
        if [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1; then
            kill -KILL "$pid" >/dev/null 2>&1 || true
        fi
    done

    "$wine_stop_bin" \
        "$WINEPREFIX" /opt/wine-stable/bin/wineserver || true

    display_lock="/tmp/.X${display_number}-lock"
    display_socket="/tmp/.X11-unix/X${display_number}"
    lock_pid="$(
        if [[ -r "$display_lock" ]]; then
            /usr/bin/tr -d '[:space:]' 2>/dev/null <"$display_lock" || true
        fi
    )"
    if [[ -n "$xvfb_pid" && "$lock_pid" == "$xvfb_pid" &&
          ! -d "/proc/$xvfb_pid" ]]; then
        rm -f "$display_lock" "$display_socket"
    fi

    if [[ "$grd_user_service_was_active" == true ]]; then
        "${systemctl_user[@]}" start gnome-remote-desktop.service \
            >/dev/null 2>&1 || true
    fi

    rm -f "$xauth_file"
}

trap cleanup EXIT
trap 'exit 0' INT TERM HUP

process_environment_value() {
    local name="$1"
    local pid="$2"

    /usr/bin/tr '\0' '\n' <"/proc/$pid/environ" 2>/dev/null | \
        /usr/bin/sed -n "s/^${name}=//p" | /usr/bin/head -n 1
}

discover_desktop_session() {
    local candidate_bus
    local candidate_display
    local candidate_session_type
    local candidate_session_id
    local candidate_state
    local candidate_wayland
    local fallback_bus=""
    local fallback_display=""
    local fallback_session_type=""
    local fallback_wayland=""
    local pid

    while read -r pid; do
        [[ -n "$pid" && -r "/proc/$pid/environ" ]] || continue
        candidate_bus="$(process_environment_value \
            DBUS_SESSION_BUS_ADDRESS "$pid")"
        candidate_display="$(process_environment_value DISPLAY "$pid")"
        candidate_wayland="$(process_environment_value WAYLAND_DISPLAY "$pid")"
        candidate_session_type="$(process_environment_value \
            XDG_SESSION_TYPE "$pid")"
        [[ -n "$candidate_bus" ]] || continue
        if [[ "$candidate_bus" == "$manager_bus" ]]; then
            candidate_display="${candidate_display:-$manager_display}"
            candidate_wayland="${candidate_wayland:-$manager_wayland}"
            candidate_session_type="${candidate_session_type:-$manager_session_type}"
        fi
        [[ -n "$candidate_display" || -n "$candidate_wayland" ]] || continue
        candidate_session_id="$(
            /usr/bin/sed -n \
                's#.*session-\([^/]*\)\.scope.*#\1#p' \
                "/proc/$pid/cgroup" 2>/dev/null | /usr/bin/head -n 1
        )"
        if [[ -n "$candidate_session_id" ]]; then
            candidate_state="$(
                /usr/bin/loginctl show-session "$candidate_session_id" \
                    --property=State --value 2>/dev/null || true
            )"
            [[ "$candidate_state" == active || \
               "$candidate_state" == online ]] || continue
        fi

        if [[ -z "$fallback_bus" ]]; then
            fallback_bus="$candidate_bus"
            fallback_display="$candidate_display"
            fallback_wayland="$candidate_wayland"
            fallback_session_type="$candidate_session_type"
        fi
        if [[ -n "$manager_display" && \
              "$candidate_display" == "$manager_display" ]]; then
            desktop_bus="$candidate_bus"
            desktop_display="$candidate_display"
            desktop_wayland="$candidate_wayland"
            desktop_session_type="$candidate_session_type"
            return 0
        fi
    done < <(/usr/bin/pgrep -u "$UID" -x gnome-shell | /usr/bin/sort -nr)

    if [[ -n "$fallback_bus" ]]; then
        desktop_bus="$fallback_bus"
        desktop_display="$fallback_display"
        desktop_wayland="$fallback_wayland"
        desktop_session_type="$fallback_session_type"
        return 0
    fi
    return 1
}

start_desktop_relay() {
    local -a desktop_environment
    local native_openssl_modules

    if ! discover_desktop_session; then
        log 'Waiting for a logged-in GNOME desktop session.'
        until discover_desktop_session; do
            sleep 5
        done
    fi

    native_openssl_modules="$(
        /usr/bin/openssl version -m | /usr/bin/sed -n \
            's/^MODULESDIR: "\(.*\)"$/\1/p'
    )"
    if [[ -z "$native_openssl_modules" ||
          ! -d "$native_openssl_modules" ]]; then
        log 'Could not discover the native OpenSSL provider directory.'
        return 1
    fi

    desktop_environment=(
        "DBUS_SESSION_BUS_ADDRESS=$desktop_bus"
        "DISPLAY=$desktop_display"
        "LD_LIBRARY_PATH=$libei_dir"
        "OPENSSL_CONF=/etc/ssl/openssl.cnf"
        "OPENSSL_MODULES=$native_openssl_modules"
    )
    if [[ -n "$desktop_wayland" ]]; then
        desktop_environment+=("WAYLAND_DISPLAY=$desktop_wayland")
    fi
    if [[ -n "$desktop_session_type" ]]; then
        desktop_environment+=("XDG_SESSION_TYPE=$desktop_session_type")
    fi

    # XRDP starts GNOME on a private session bus. The regular user unit runs
    # on /run/user/$UID/bus and cannot see that shell, so launch GRD on the
    # bus belonging to the desktop that is actually being shared.
    if "${systemctl_user[@]}" is-active --quiet \
        gnome-remote-desktop.service; then
        grd_user_service_was_active=true
    fi
    "${systemctl_user[@]}" stop gnome-remote-desktop.service \
        >/dev/null 2>&1 || true
    /usr/bin/env "${desktop_environment[@]}" \
        /usr/libexec/gnome-remote-desktop-daemon --rdp-port "$rdp_port" \
        >>"$state_dir/gnome-remote-desktop.log" 2>&1 &
    grd_pid=$!

    for _ in {1..150}; do
        if ! kill -0 "$grd_pid" >/dev/null 2>&1; then
            log 'GNOME Desktop Sharing exited during startup.'
            return 1
        fi
        if /usr/bin/ss -H -ltnp "sport = :$rdp_port" 2>/dev/null | \
            /usr/bin/grep -q 'gnome-remote-de'; then
            log "GNOME Desktop Sharing is relaying $desktop_session_type ${desktop_display:-$desktop_wayland}."
            return 0
        fi
        sleep 0.1
    done

    log "GNOME Desktop Sharing did not open 127.0.0.1:$rdp_port."
    return 1
}

mkdir -p \
    "$state_dir" \
    "$runtime_dir" \
    "$WINEPREFIX/drive_c/users/$bridge_user/Temp"
chmod 700 "$runtime_dir"
log "Using private display $DISPLAY at $resolution and RDP port $rdp_port."

if [[ ! -x "$wine_stop_bin" ]]; then
    log 'The prefix-scoped Wine cleanup helper is missing.'
    exit 1
fi

if ! start_desktop_relay; then
    exit 1
fi

touch "$xauth_file"
chmod 600 "$xauth_file"
/usr/bin/xauth -f "$xauth_file" add "$DISPLAY" . "$(/usr/bin/mcookie)"
export XAUTHORITY="$xauth_file"

/usr/bin/Xvfb "$DISPLAY" \
    -screen 0 "${resolution}x24" \
    -dpi 96 \
    -nolisten tcp \
    -noreset \
    -auth "$xauth_file" \
    >>"$state_dir/xvfb.log" 2>&1 &
xvfb_pid=$!

x_ready=false
for _ in {1..100}; do
    if /usr/bin/xdpyinfo -display "$DISPLAY" >/dev/null 2>&1; then
        x_ready=true
        break
    fi
    sleep 0.1
done

if [[ "$x_ready" != true ]]; then
    log 'The private X11 display did not become ready.'
    exit 1
fi

/usr/bin/openbox >>"$state_dir/openbox.log" 2>&1 &
openbox_pid=$!

if [[ ! -f "$freerdp_exe" ]]; then
    log 'The Windows FreeRDP client is missing from the Wine prefix.'
    exit 1
fi

if [[ ! -f "$input_bridge_dll" || ! -f "$input_broker_exe" ||
      ! -f "$input_injector_exe" || ! -f "$service_control_exe" ]]; then
    log 'The UU input compatibility bridge is missing from the Wine prefix.'
    exit 1
fi

select_network_interface
wine_host_environment=(/usr/bin/env)
if [[ -n "$active_network_interface" ]]; then
    if [[ -f "$network_filter" ]]; then
        wine_host_environment+=(
            "UURB_NETWORK_INTERFACE=$active_network_interface"
            "LD_PRELOAD=$network_filter"
        )
    else
        log 'The optional UU network filter is missing; preserving the unfiltered adapter list.'
        active_network_interface=""
    fi
fi

password="$(
    /usr/bin/env DBUS_SESSION_BUS_ADDRESS="$desktop_bus" \
        /usr/bin/secret-tool lookup service uu-desktop-bridge \
        username "$bridge_user" || true
)"
if [[ -z "$password" ]]; then
    log 'The RDP bridge password is missing from the login keyring.'
    exit 1
fi

tls_cert="$(/usr/bin/gsettings get \
    org.gnome.desktop.remote-desktop.rdp tls-cert)"
tls_cert="${tls_cert#\'}"
tls_cert="${tls_cert%\'}"
if [[ ! -f "$tls_cert" ]]; then
    log 'The configured GNOME RDP TLS certificate is missing.'
    exit 1
fi
tls_fingerprint="$(
    /usr/bin/openssl x509 -in "$tls_cert" -outform DER | \
        /usr/bin/sha256sum | /usr/bin/awk '{print $1}'
)"
cert_option="/cert:fingerprint:sha256:$tls_fingerprint"

/usr/bin/timeout --kill-after=1s 5s \
    /usr/bin/env WINEPREFIX="$WINEPREFIX" \
    /opt/wine-stable/bin/wineserver -k >/dev/null 2>&1 || true
/usr/bin/timeout --kill-after=1s 5s \
    /usr/bin/env WINEPREFIX="$WINEPREFIX" \
    /opt/wine-stable/bin/wineserver -w >/dev/null 2>&1 || true

"${wine_host_environment[@]}" "$compat_dir/winlogon.exe" \
    >>"$state_dir/winlogon.log" 2>&1 &
winlogon_pid=$!

uu_ready=false
for _ in {1..120}; do
    if pgrep -u "$UID" -f 'GameViewerServer\.exe' >/dev/null && \
       pgrep -u "$UID" -f 'GameViewerHealthd' >/dev/null; then
        uu_ready=true
        break
    fi
    sleep 0.25
done

if [[ "$uu_ready" != true ]]; then
    log 'UU Remote background processes did not become ready.'
    exit 1
fi

/opt/wine-stable/bin/wine "$input_broker_exe" \
    >>"$state_dir/input-broker.log" 2>&1 &
input_broker_pid=$!

sleep 0.2
if ! kill -0 "$input_broker_pid" >/dev/null 2>&1; then
    log 'The UU input broker exited during startup.'
    exit 1
fi

input_bridge_windows_path="$(
    /opt/wine-stable/bin/winepath -w "$input_bridge_dll"
)"
if ! /opt/wine-stable/bin/wine "$input_injector_exe" \
    "$input_bridge_windows_path" \
    >>"$state_dir/input-injector.log" 2>&1; then
    log 'Could not inject the UU input compatibility bridge.'
    exit 1
fi
server_pid="$(pgrep -o -u "$UID" -f 'GameViewerServer\.exe')"

/opt/wine-stable/bin/wine "$freerdp_exe" \
    "/v:127.0.0.1:$rdp_port" \
    "/u:$bridge_user" \
    /from-stdin:force \
    "$cert_option" \
    /sspi-module:'C:\Program Files\FreeRDP\winpr-sspi-shim.dll' \
    /auth-pkg-list:'none,ntlm' \
    /network:auto \
    "/size:$resolution" \
    /bpp:32 \
    /gdi:sw \
    /audio-mode:2 \
    /prevent-session-lock:180 \
    /t:Ubuntu-Desktop-Relay \
    +f \
    -toggle-fullscreen \
    -decorations \
    -suppress-output \
    +clipboard \
    +auto-reconnect \
    /auto-reconnect-max-retries:0 \
    /log-level:WARN \
    <<<"$password" >>"$state_dir/freerdp.log" 2>&1 &
freerdp_pid=$!
unset password

relay_ready=false
for _ in {1..150}; do
    if /usr/bin/xdotool search --name Ubuntu-Desktop-Relay \
        >/dev/null 2>&1; then
        relay_ready=true
        break
    fi
    if ! kill -0 "$freerdp_pid" >/dev/null 2>&1; then
        break
    fi
    sleep 0.1
done

if [[ "$relay_ready" != true ]]; then
    log 'FreeRDP did not create the Ubuntu desktop relay window.'
    exit 1
fi

/usr/bin/xdotool search --name Ubuntu-Desktop-Relay \
    windowactivate --sync >/dev/null 2>&1 || true

bootstrap_account() {
    /opt/wine-stable/bin/wine "$service_control_exe" \
        GameViewerService 133 \
        >>"$state_dir/service-control.log" 2>&1 || true
    /opt/wine-stable/bin/wine start /unix "$uu_app_dir/GameViewer.exe" \
        >>"$state_dir/client-bootstrap.log" 2>&1 || true

    sleep 1
    /usr/bin/xdotool search --onlyvisible --name '网易UU远程' \
        windowminimize >/dev/null 2>&1 || true
    /usr/bin/xdotool search --name Ubuntu-Desktop-Relay \
        windowactivate --sync >/dev/null 2>&1 || true
}

# UU's GUI sends the account-login IPC message that makes the background
# server visible to other devices. Let it exit normally: forcibly closing it
# also asks the server to exit.
bootstrap_account

supervise_server() {
    local last_pid="$1"
    local candidate
    local current_default_interface
    local grd_fd_count
    local health_checks=0
    local missing_checks=0
    local network_route_checks=0

    while true; do
        candidate="$(pgrep -o -u "$UID" -f 'GameViewerServer\.exe' || true)"
        if [[ -z "$candidate" ]]; then
            missing_checks=$((missing_checks + 1))
            if ((missing_checks >= 40)); then
                log 'UU server was absent for 10 seconds; restarting the bridge.'
                return 1
            fi
        else
            missing_checks=0
        fi
        if [[ -n "$candidate" && "$candidate" != "$last_pid" ]]; then
            sleep 0.25
            if /opt/wine-stable/bin/wine "$input_injector_exe" \
                "$input_bridge_windows_path" \
                >>"$state_dir/input-injector.log" 2>&1; then
                last_pid="$candidate"
                log "Re-injected UU server process $candidate."
                bootstrap_account
            else
                log "Could not re-inject UU server process $candidate."
                return 1
            fi
        fi
        health_checks=$((health_checks + 1))
        if ((grd_fd_restart_threshold > 0 && health_checks >= 40)); then
            health_checks=0
            if [[ -d "/proc/$grd_pid/fd" ]]; then
                grd_fd_count="$(
                    /usr/bin/find "/proc/$grd_pid/fd" -maxdepth 1 \
                        -type l -printf '.\n' 2>/dev/null | /usr/bin/wc -l
                )"
                if ((grd_fd_count >= grd_fd_restart_threshold)); then
                    log "GNOME Remote Desktop reached $grd_fd_count file descriptors; restarting the relay before exhaustion."
                    return 1
                fi
            fi
        fi
        if [[ "$network_interface" == default && \
              -n "$active_network_interface" ]]; then
            network_route_checks=$((network_route_checks + 1))
            if ((network_route_checks >= 40)); then
                network_route_checks=0
                current_default_interface="$(default_network_interface)"
                if [[ -n "$current_default_interface" && \
                      "$current_default_interface" != \
                      "$active_network_interface" ]]; then
                    log "Default network interface changed from $active_network_interface to $current_default_interface; restarting UU on the preferred route."
                    return 1
                fi
            fi
        fi
        sleep 0.25
    done
}

supervise_server "$server_pid" &
server_supervisor_pid=$!

log "UU Remote and the Windows RDP relay share DISPLAY=$DISPLAY."

set +e
wait -n \
    "$xvfb_pid" \
    "$openbox_pid" \
    "$grd_pid" \
    "$freerdp_pid" \
    "$winlogon_pid" \
    "$input_broker_pid" \
    "$server_supervisor_pid"
set -e
log 'A bridge process exited; systemd will restart the complete relay.'
exit 1
