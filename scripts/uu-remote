#!/usr/bin/env bash

set -Eeuo pipefail

export WINEPREFIX="${WINEPREFIX:-$HOME/.local/share/wineprefixes/uu-remote}"
export WINEDEBUG="${WINEDEBUG:--all}"

wine_bin="${WINE_BIN:-/opt/wine-stable/bin/wine}"
wineserver_bin="${WINESERVER_BIN:-/opt/wine-stable/bin/wineserver}"
app_dir="$WINEPREFIX/drive_c/Program Files/Netease/GameViewer"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/uu-remote"
systemctl_user=(
    /usr/bin/env
    "DBUS_SESSION_BUS_ADDRESS=unix:path=${XDG_RUNTIME_DIR:-/run/user/$UID}/bus"
    /usr/bin/systemctl --user
)

notify_error() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send 'UU Remote' "$1"
    fi
    printf '%s\n' "$1" >&2
}

mkdir -p "$state_dir"

case "${1:-open}" in
    status)
        exec "${systemctl_user[@]}" status uu-remote-bridge.service --no-pager
        ;;
    restart)
        exec "${systemctl_user[@]}" restart uu-remote-bridge.service
        ;;
    stop)
        exec "${systemctl_user[@]}" stop uu-remote-bridge.service
        ;;
    logs)
        exec journalctl --user -fu uu-remote-bridge.service
        ;;
    login)
        shift || true
        if [[ -z "${DISPLAY:-}" ]]; then
            notify_error 'Run account login from a visible desktop terminal.'
            exit 1
        fi
        if [[ ! -f "$app_dir/GameViewer.exe" ]]; then
            notify_error 'UU Remote is not installed in the bridge Wine prefix.'
            exit 1
        fi
        "${systemctl_user[@]}" stop uu-remote-bridge.service
        /usr/bin/timeout --kill-after=2s 10s \
            "$wineserver_bin" -k >/dev/null 2>&1 || true
        /usr/bin/timeout --kill-after=2s 10s \
            "$wineserver_bin" -w >/dev/null 2>&1 || true
        restart_bridge() {
            /usr/bin/timeout --kill-after=2s 10s \
                "$wineserver_bin" -k >/dev/null 2>&1 || true
            /usr/bin/timeout --kill-after=2s 10s \
                "$wineserver_bin" -w >/dev/null 2>&1 || true
            "${systemctl_user[@]}" start uu-remote-bridge.service
        }
        trap restart_bridge EXIT
        cd "$app_dir"
        "$wine_bin" GameViewer.exe "$@" >>"$state_dir/client.log" 2>&1
        exit 0
        ;;
    open)
        shift || true
        ;;
    *)
        printf 'usage: uu-remote [open|login|status|restart|stop|logs]\n' >&2
        exit 2
        ;;
esac

if ! "${systemctl_user[@]}" start uu-remote-bridge.service; then
    notify_error 'The Ubuntu desktop bridge could not start.'
    exit 1
fi

for _ in {1..120}; do
    if pgrep -u "$UID" -f 'GameViewerServer\.exe' >/dev/null; then
        break
    fi
    sleep 0.25
done

if ! pgrep -u "$UID" -f 'GameViewerServer\.exe' >/dev/null; then
    notify_error 'The Ubuntu desktop bridge is not ready.'
    exit 1
fi
if [[ ! -f "$app_dir/GameViewer.exe" ]]; then
    notify_error 'UU Remote is not installed in the bridge Wine prefix.'
    exit 1
fi

cd "$app_dir"
exec "$wine_bin" GameViewer.exe "$@" >>"$state_dir/client.log" 2>&1
